---
import Layout from '../../layouts/Layout.astro';
import { sanityClient, urlFor } from '../../lib/sanity';

// Required for static builds
export async function getStaticPaths() {
  const products = await sanityClient.fetch(`
    *[_type == "product"] { "slug": slug.current }
  `);

  return products.map((product: any) => ({
    params: { slug: product.slug }
  }));
}

const { slug } = Astro.params;

const product = await sanityClient.fetch(`
  *[_type == "product" && slug.current == $slug][0] {
    title,
    price,
    "images": images[].asset->url,
    description,
    story,
    woodType,
    finish,
    materials,
    dimensions,
    careInstructions,
    inStock,
    shippingAvailable,
    localPickupOnly,
    isCustomizable
  }
`, { slug });
---

<Layout 
  title={product ? `${product.title} - Cackalacky Craft` : "Product Not Found"}
>

  {product ? (
    <div class="max-w-7xl mx-auto px-6 py-12">
      <div class="grid md:grid-cols-2 gap-12 lg:gap-16">

        <!-- Images -->
        <div class="space-y-6">
          {product.images?.length > 0 ? (
            product.images.map((img: any, i: number) => (
              <img 
                key={i}
                src={urlFor(img).width(1200).quality(85).url()} 
                alt={product.title}
                class="w-full rounded-3xl shadow-md"
                loading="lazy"
              />
            ))
          ) : (
            <div class="aspect-square bg-gray-200 rounded-3xl flex items-center justify-center">
              <p class="text-gray-500">No images available yet</p>
            </div>
          )}
        </div>

        <!-- Product Details -->
        <div class="space-y-8">
          <div>
            <h1 class="text-5xl font-heading text-primary leading-tight">{product.title}</h1>
            <p class="text-4xl text-accent1 font-semibold mt-6">${product.price}</p>
          </div>

          <div class="prose max-w-none text-lg">
            <p>{product.description}</p>
            {product.story && <p class="italic mt-6">{product.story}</p>}
          </div>

          <div class="grid grid-cols-2 gap-x-8 gap-y-6 text-sm">
            {product.woodType && (
              <div>
                <p class="font-medium text-dark/70">Wood Type</p>
                <p>{product.woodType}</p>
              </div>
            )}
            {product.finish && (
              <div>
                <p class="font-medium text-dark/70">Finish</p>
                <p>{product.finish}</p>
              </div>
            )}
          </div>

          <a 
            href="https://square.link/your-store" 
            target="_blank"
            class="btn inline-block w-full text-center py-4 text-lg"
          >
            Buy on Square
          </a>
        </div>
      </div>
    </div>
  ) : (
    <div class="text-center py-32">
      <h2 class="text-4xl font-heading">Product not found</h2>
      <a href="/gallery" class="mt-8 inline-block text-accent1 underline">← Back to Gallery</a>
    </div>
  )}

</Layout>