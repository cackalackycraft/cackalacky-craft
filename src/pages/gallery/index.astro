---
import Layout from '../layouts/Layout.astro';
import { sanityClient, urlFor } from '../lib/sanity';

const featuredProducts = await sanityClient.fetch(`
  *[_type == "product" && featured == true] | order(title asc) [0...6] {
    title,
    slug,
    price,
    "images": images[].asset->url,
    woodType
  }
`);
---

<Layout title="Cackalacky Craft - Handcrafted Woodwork">

  <!-- Hero -->
  <section class="min-h-[85vh] flex items-center justify-center bg-[#5c3a2a] text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/hero-wood.jpg')] bg-cover bg-center opacity-30"></div>
    <div class="relative text-center px-6 max-w-5xl mx-auto">
      <h1 class="text-6xl md:text-7xl font-heading tracking-tight leading-none mb-8">
        Timeless Craft.<br>Carolina Soul.
      </h1>
      <p class="text-xl md:text-2xl max-w-2xl mx-auto mb-12 text-white/90">
        Handcrafted wooden furniture and decor built to last generations.
      </p>
      <a href="/gallery" class="btn text-lg px-14 py-5 inline-block">Explore the Collection</a>
    </div>
  </section>

  <!-- Featured Works -->
  <section class="py-24 bg-[#F5F0E1]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex justify-between items-baseline mb-12">
        <h2 class="text-5xl font-heading text-primary">Featured Works</h2>
        <a href="/gallery" class="text-accent1 hover:underline text-lg">View All →</a>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10">
        {featuredProducts.length > 0 ? (
          featuredProducts.map((product: any) => (
            <a href={`/gallery/${product.slug?.current}`} class="card group">
              <div class="aspect-[4/3] bg-gray-200 overflow-hidden">
                {product.images?.[0] ? (
                  <img 
                    src={urlFor(product.images[0]).width(600).height(450).fit('crop').url()} 
                    alt={product.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-gray-400">Image coming soon</div>
                )}
              </div>
              <div class="p-8">
                <h3 class="text-2xl font-medium mb-3">{product.title}</h3>
                <p class="text-accent1 font-semibold text-3xl">${product.price}</p>
                {product.woodType && <p class="text-sm text-dark/70 mt-4">Handcrafted in {product.woodType}</p>}
              </div>
            </a>
          ))
        ) : (
          <div class="col-span-3 text-center py-20 text-dark/60">
            <p class="text-2xl">Featured pieces coming soon...</p>
          </div>
        )}
      </div>
    </div>
  </section>

</Layout>