---
import Layout from '../../layouts/Layout.astro';
import { sanityClient, urlFor } from '../../lib/sanity';

const products = await sanityClient.fetch(`
  *[_type == "product"] | order(featured desc, _createdAt desc) {
    title,
    slug,
    price,
    "images": images[].asset->url,
    woodType
  }
`);
---

<Layout title="Gallery - Cackalacky Craft">

  <div class="container py-16">
    <h1 class="text-5xl font-heading text-center mb-4">Our Collection</h1>
    <p class="text-xl text-center text-dark/70 mb-16">Each piece is made by hand with care and attention to detail.</p>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10">
      {products.map((product: any) => (
        <a href={`/gallery/${product.slug?.current}`} class="card group">
          <div class="aspect-[4/3] bg-gray-200 overflow-hidden">
            {product.images?.[0] ? (
              <img 
                src={urlFor(product.images[0]).width(600).height(450).fit('crop').url()} 
                alt={product.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-gray-400">Image coming soon</div>
            )}
          </div>
          <div class="p-8">
            <h3 class="text-2xl font-medium mb-3">{product.title}</h3>
            <p class="text-accent1 font-semibold text-3xl">${product.price}</p>
            {product.woodType && <p class="text-sm text-dark/70 mt-4">• {product.woodType}</p>}
          </div>
        </a>
      ))}
    </div>
  </div>

</Layout>