---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="About Us - Cackalacky Craft" 
  description="Our story, values, and commitment to handcrafted woodwork."
>

  <div class="max-w-4xl mx-auto px-6 py-20">
    <h1 class="text-5xl font-heading text-primary mb-10 text-center">Our Story</h1>
    
    <div class="prose prose-lg max-w-none text-dark/80">
      <p class="text-xl leading-relaxed">
        Cackalacky Craft was born from a love of wood, tradition, and the Carolina way of life. 
        Every piece is designed and built by hand using responsibly sourced hardwoods and time-honored techniques.
      </p>
      
      <h2 class="text-3xl font-heading text-primary mt-16 mb-6">Why We Craft</h2>
      <ul class="list-none space-y-4 text-lg">
        <li class="flex gap-4">🌳 Sustainable & locally sourced materials</li>
        <li class="flex gap-4">🔨 Built to last generations, not seasons</li>
        <li class="flex gap-4">❤️ Made with care in small batches</li>
      </ul>
    </div>
  </div>

</Layout>