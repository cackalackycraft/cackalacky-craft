---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contact - Cackalacky Craft" 
  description="Get in touch with us for custom orders, questions, or just to say hello."
>

  <div class="max-w-4xl mx-auto px-6 py-20">
    <h1 class="text-5xl font-heading text-primary mb-4 text-center">Let's Talk Wood</h1>
    <p class="text-center text-xl text-dark/70 mb-12">Custom orders, wholesale, or general inquiries welcome.</p>

    <div class="grid md:grid-cols-2 gap-16">
      <!-- Contact Form -->
      <div>
        <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-6">
          <div>
            <label class="block text-sm font-medium mb-2">Name</label>
            <input type="text" name="name" required
                   class="w-full px-4 py-3 border border-primary/20 rounded-2xl focus:outline-none focus:border-accent1"/>
          </div>
          
          <div>
            <label class="block text-sm font-medium mb-2">Email</label>
            <input type="email" name="email" required
                   class="w-full px-4 py-3 border border-primary/20 rounded-2xl focus:outline-none focus:border-accent1"/>
          </div>
          
          <div>
            <label class="block text-sm font-medium mb-2">Message</label>
            <textarea name="message" rows="6" required
                      class="w-full px-4 py-3 border border-primary/20 rounded-3xl focus:outline-none focus:border-accent1"></textarea>
          </div>

          <button type="submit"
                  class="w-full bg-primary text-white py-4 rounded-full text-lg font-medium hover:bg-accent1 transition-all">
            Send Message
          </button>
        </form>
      </div>

      <!-- Contact Info -->
      <div class="space-y-8 pt-8">
        <div>
          <p class="font-medium text-lg mb-2">📍 Location</p>
          <p class="text-dark/70">North Carolina, USA</p>
        </div>
        <div>
          <p class="font-medium text-lg mb-2">📧 Email</p>
          <a href="mailto:hello@cackalackycraft.com" class="text-accent1 hover:underline">hello@cackalackycraft.com</a>
        </div>
        <div>
          <p class="font-medium text-lg mb-2">📱 Phone</p>
          <a href="tel:5551234567" class="text-accent1 hover:underline">(555) 123-4567</a>
        </div>
      </div>
    </div>
  </div>

</Layout>