---
import SocialIcons from './SocialIcons.astro';
---

<header>
  <div class="header-inner">
    <!-- Logo -->
    <a href="/" class="logo">
      <div class="w-10 h-10 bg-[#5c3a2a] rounded-2xl flex items-center justify-center text-white text-2xl font-bold">
        CC
      </div>
      <div>
        <span class="text-3xl font-heading tracking-tight">Cackalacky</span>
        <span class="text-xl font-heading text-[#8A9A5B] block -mt-1">Craft</span>
      </div>
    </a>

    <!-- Navigation -->
    <nav class="nav-links hidden md:flex items-center">
      <a href="/gallery">Gallery</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
      <a href="https://square.link/your-store" target="_blank" class="btn ml-6">Shop Now</a>
    </nav>

    <!-- Mobile Menu Button (if needed later) -->
    <div class="md:hidden">
      <!-- We'll add hamburger later if you want -->
    </div>
  </div>
</header>