---
import SocialIcons from './SocialIcons.astro';
---

<header>
  <div class="header-content">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3">
      <div class="w-11 h-11 bg-[#5c3a2a] rounded-2xl flex items-center justify-center text-white text-2xl font-bold">
        CC
      </div>
      <div>
        <span class="text-3xl font-heading tracking-tight text-[#5c3a2a]">Cackalacky</span>
        <span class="text-xl font-heading text-[#8A9A5B] block -mt-1">Craft</span>
      </div>
    </a>

    <!-- Navigation -->
    <nav class="hidden md:flex items-center">
      <a href="/gallery">Gallery</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </nav>

    <!-- Right Side -->
    <div class="flex items-center gap-6">
      <SocialIcons />
      <a href="https://square.link/your-store" target="_blank" class="btn">Shop Now</a>
    </div>
  </div>
</header>