---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title = "Cackalacky Craft", description = "Handcrafted woodwork from the Carolinas" } = Astro.props;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Main Stylesheet -->
  <link rel="stylesheet" href="/styles/global.css" />

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&family=ChunkFive+Print&display=swap" rel="stylesheet" />
</head>
<body class="bg-[#F5F0E1] text-[#3C3C3C]">
  <Header />
  <slot />
  <Footer />
</body>
</html>